# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
jspm_packages/

# ---------------------------------------------------------------------------
# Environment files — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# ---------------------------------------------------------------------------
# Next.js (frontend)
# ---------------------------------------------------------------------------
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/next-env.d.ts
frontend/.turbo/

# ---------------------------------------------------------------------------
# NestJS (backend)
# ---------------------------------------------------------------------------
backend/dist/
backend/build/
backend/.turbo/

# ---------------------------------------------------------------------------
# Prisma
# Keep real migrations; only ignore local squashed/temp artifacts.
# ---------------------------------------------------------------------------
backend/prisma/migrations/*_squashed
backend/prisma/*.db
backend/prisma/*.db-journal

# ---------------------------------------------------------------------------
# TypeScript build artifacts
# ---------------------------------------------------------------------------
*.tsbuildinfo
**/*.tsbuildinfo

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
coverage/
**/coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# Caches
# ---------------------------------------------------------------------------
.eslintcache
.cache/
.npm/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Claude Code (auto-memory is personal to each developer)
# ---------------------------------------------------------------------------
.claude/memory/
.claude/settings.local.json

# ---------------------------------------------------------------------------
# Project-local prompt notes
# ---------------------------------------------------------------------------
PROMPT.md
